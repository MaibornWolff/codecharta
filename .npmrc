engine-strict=true

# Never execute dependency lifecycle scripts (preinstall/install/postinstall) during
# npm install — they are the main npm supply-chain attack vector. No dependency of the
# root project needs an install script. This also skips the root prepare script (husky),
# so run `npm run prepare` once after a fresh clone to set up the git hooks (the mise
# install task does this automatically).
ignore-scripts=true
