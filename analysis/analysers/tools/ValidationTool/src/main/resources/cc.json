{
  "$ref": "#/definitions/ExportCCFileAny",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ExportCCFileAny": {
      "anyOf": [
        { "$ref": "#/definitions/ExportCCFile" },
        { "$ref": "#/definitions/ExportCCFile2" }
      ]
    },
    "AttributeTypes": {
      "properties": {
        "edges": {
          "additionalProperties": {
            "enum": ["absolute", "relative"],
            "type": "string"
          },
          "type": "object"
        },
        "nodes": {
          "additionalProperties": {
            "enum": ["absolute", "relative"],
            "type": "string"
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "CodeMapNode": {
      "properties": {
        "attributes": {
          "$ref": "#/definitions/KeyValuePair"
        },
        "children": {
          "items": {
            "$ref": "#/definitions/CodeMapNode"
          },
          "type": "array"
        },
        "deltas": {
          "additionalProperties": {
            "type": "number"
          },
          "type": "object"
        },
        "edgeAttributes": {
          "additionalProperties": {
            "$ref": "#/definitions/EdgeMetricCount"
          },
          "type": "object"
        },
        "fixedPosition": {
          "$ref": "#/definitions/FixedPosition"
        },
        "id": {
          "type": "number"
        },
        "isExcluded": {
          "type": "boolean"
        },
        "isFlattened": {
          "type": "boolean"
        },
        "link": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "checksum": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/NodeType"
        }
      },
      "required": ["name", "type"],
      "type": "object"
    },
    "Edge": {
      "properties": {
        "attributes": {
          "$ref": "#/definitions/KeyValuePair"
        },
        "fromNodeName": {
          "type": "string"
        },
        "toNodeName": {
          "type": "string"
        },
        "visible": {
          "$ref": "#/definitions/EdgeVisibility"
        }
      },
      "required": ["attributes", "fromNodeName", "toNodeName"],
      "type": "object"
    },
    "EdgeMetricCount": {
      "properties": {
        "incoming": {
          "type": "number"
        },
        "outgoing": {
          "type": "number"
        }
      },
      "required": ["incoming", "outgoing"],
      "type": "object"
    },
    "EdgeVisibility": {
      "enum": ["both", "from", "none", "to"],
      "type": "string"
    },
    "ExportBlacklistItem": {
      "properties": {
        "path": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/ExportBlacklistType"
        }
      },
      "required": ["path", "type"],
      "type": "object"
    },
    "ExportBlacklistType": {
      "enum": ["exclude", "hide"],
      "type": "string"
    },
    "Data": {
      "properties": {
        "apiVersion": {
          "type": "string"
        },
        "attributeTypes": {
          "anyOf": [
            {
              "$ref": "#/definitions/OldAttributeTypes"
            },
            {
              "$ref": "#/definitions/AttributeTypes"
            }
          ]
        },
        "blacklist": {
          "items": {
            "$ref": "#/definitions/ExportBlacklistItem"
          },
          "type": "array"
        },
        "edges": {
          "items": {
            "$ref": "#/definitions/Edge"
          },
          "type": "array"
        },
        "markedPackages": {
          "items": {
            "$ref": "#/definitions/MarkedPackage"
          },
          "type": "array"
        },
        "nodes": {
          "items": {
            "$ref": "#/definitions/CodeMapNode"
          },
          "type": "array"
        },
        "projectName": {
          "type": "string"
        }
      },
      "required": ["apiVersion", "nodes", "projectName"],
      "type": "object"
    },
    "ExportCCFile": {
      "properties": {
        "checksum": {
          "type": "string"
        },
        "data": {
          "$ref": "#/definitions/Data"
        }
      },
      "required": ["checksum", "data"],
      "type": "object"
    },
    "FixedPosition": {
      "properties": {
        "height": {
          "type": "number"
        },
        "left": {
          "type": "number"
        },
        "top": {
          "type": "number"
        },
        "width": {
          "type": "number"
        }
      },
      "required": ["height", "left", "top", "width"],
      "type": "object"
    },
    "KeyValuePair": {
      "additionalProperties": {
        "type": "number"
      },
      "type": "object"
    },
    "MarkedPackage": {
      "properties": {
        "color": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": ["color", "path"],
      "type": "object"
    },
    "NodeType": {
      "enum": ["File", "Folder"],
      "type": "string"
    },
    "OldAttributeTypes": {
      "properties": {
        "edges": {
          "additionalItems": {
            "anyOf": [
              {
                "additionalProperties": {
                  "enum": ["absolute", "relative"],
                  "type": "string"
                },
                "type": "object"
              }
            ]
          },
          "items": [
            {
              "additionalProperties": {
                "enum": ["absolute", "relative"],
                "type": "string"
              },
              "type": "object"
            }
          ],
          "minItems": 0,
          "type": "array"
        },
        "nodes": {
          "additionalItems": {
            "anyOf": [
              {
                "additionalProperties": {
                  "enum": ["absolute", "relative"],
                  "type": "string"
                },
                "type": "object"
              }
            ]
          },
          "items": [
            {
              "additionalProperties": {
                "enum": ["absolute", "relative"],
                "type": "string"
              },
              "type": "object"
            }
          ],
          "minItems": 0,
          "type": "array"
        }
      },
      "type": "object"
    },
    "Meta": {
      "properties": {
        "projectName": { "type": "string" },
        "apiVersion": { "type": "string" },
        "checksum": { "type": "string" },
        "commitHash": { "type": "string" }
      },
      "required": ["projectName", "apiVersion", "checksum"],
      "type": "object"
    },
    "FileNode": {
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "$ref": "#/definitions/NodeType" },
        "children": {
          "items": { "$ref": "#/definitions/FileNode" },
          "type": "array"
        },
        "contentHash": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["id", "name", "type"],
      "type": "object"
    },
    "AttributeDescriptor": {
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "hintLowValue": { "type": "string" },
        "hintHighValue": { "type": "string" },
        "link": { "type": "string" },
        "direction": { "type": "number" },
        "analyzers": {
          "items": { "type": "string" },
          "type": "array"
        }
      },
      "type": "object"
    },
    "Edge2": {
      "properties": {
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "attributes": { "type": "object" }
      },
      "required": ["fromId", "toId"],
      "type": "object"
    },
    "MetricsLens": {
      "properties": {
        "attributes": {
          "additionalProperties": { "type": "object" },
          "type": "object"
        },
        "attributeDescriptors": {
          "additionalProperties": { "$ref": "#/definitions/AttributeDescriptor" },
          "type": "object"
        },
        "attributeTypes": {
          "additionalProperties": {
            "enum": ["absolute", "relative"],
            "type": "string"
          },
          "type": "object"
        },
        "clusters": { "type": "array" }
      },
      "type": "object"
    },
    "DependencyLens": {
      "properties": {
        "edges": {
          "items": { "$ref": "#/definitions/Edge2" },
          "type": "array"
        },
        "attributeDescriptors": {
          "additionalProperties": { "$ref": "#/definitions/AttributeDescriptor" },
          "type": "object"
        },
        "attributeTypes": {
          "additionalProperties": {
            "enum": ["absolute", "relative"],
            "type": "string"
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "Lenses": {
      "properties": {
        "metrics": { "$ref": "#/definitions/MetricsLens" },
        "dependency": { "$ref": "#/definitions/DependencyLens" },
        "domain": { "type": "object" },
        "security": { "type": "object" }
      },
      "type": "object"
    },
    "ExportCCFile2": {
      "properties": {
        "meta": { "$ref": "#/definitions/Meta" },
        "files": {
          "items": { "$ref": "#/definitions/FileNode" },
          "type": "array"
        },
        "lenses": { "$ref": "#/definitions/Lenses" }
      },
      "required": ["meta", "files", "lenses"],
      "type": "object"
    }
  }
}
