engine-strict=true

# Never execute dependency lifecycle scripts (preinstall/install/postinstall) during
# npm install — they are the main npm supply-chain attack vector. All native dependencies
# in this project ship prebuilt platform packages and work without their (fallback)
# install scripts. The one exception is electron, whose binary download is performed on
# demand by script/ensureElectron.js (wired into `npm run start` and `npm run package`).
ignore-scripts=true
